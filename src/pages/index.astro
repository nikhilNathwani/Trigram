---
import BaseLayout from "../layouts/BaseLayout.astro";
import TitleScreen from "../components/TitleScreen.astro";
import TrigramRevealScreen from "../components/TrigramRevealScreen.astro";
import YouWinScreen from "../components/YouWinScreen.astro";
import HelpDialog from "../components/HelpDialog.astro";
import StatsDialog from "../components/StatsDialog.astro";
import NoLandscapeScreen from "../components/NoLandscapeScreen.astro";
import Header from "../components/Header.astro";
import GameBoard from "../components/GameBoard.astro";
import Keyboard from "../components/Keyboard.astro";
---

<BaseLayout>
	<div id="app">
		<TitleScreen />
		<TrigramRevealScreen />
		<YouWinScreen />
		<HelpDialog />
		<StatsDialog />
		<NoLandscapeScreen />
		<div id="frame">
			<Header />
			<GameBoard />
			<Keyboard />
		</div>
	</div>
</BaseLayout>
