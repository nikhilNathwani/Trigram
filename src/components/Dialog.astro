---
// Shared chrome for helpDialog/statsDialog (see the naming-convention
// comment at the top of ui/modal.js): both real <dialog>s, opened/closed
// via .showModal()/.close() in ui/modal.js, which looks each up by the id
// passed in here (document.getElementById("helpDialog"/"statsDialog")) and
// wires its own close button via `.querySelector(".closeButton")` scoped
// to that dialog — so id must stay unique per caller, and the
// .closeButton/.closeRow structure below must stay exactly as-is.
const { id } = Astro.props;
---

<dialog class="modal-content screen" id={id}>
	<div class="closeRow">
		<div class="closeButton">
			<i class="fa-solid fa-xmark" aria-hidden="true"></i>
		</div>
	</div>
	<slot />
</dialog>

<style>
	.modal-content {
		width: min(500px, 94vw);
		max-height: 85vh;
		overflow: auto;
		border: 3px solid;
		margin: 4rem auto;
		padding: 1.5rem;
		background-color: var(--color-light);
		color: var(--color-darker);
		border-color: var(--color-darker);
	}

	.modal-content::backdrop {
		cursor: pointer;
		background-color: var(--color-translucent);
	}

	.closeRow {
		display: flex;
		flex-flow: row nowrap;
		align-items: center;
		justify-content: end;
	}

	.closeButton {
		background-color: transparent;
		border: none;
		cursor: pointer;
	}

	.fa-xmark {
		font-size: 1.25rem;
	}
</style>
