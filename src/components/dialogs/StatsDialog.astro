---
import Dialog from "./Dialog.astro";
---

<Dialog id="statsDialog">
	<div id="nextGameCountdownDiv">
		<p id="nextGameCountdown">Next game starts on Monday</p>
		<br />
	</div>
	<h1 id="statsTitle">Words &amp; Stats</h1>
	<div id="wordList">
		<h2 id="wordListTitle">Your Words</h2>
		<div id="wordListValue">
			<p id="wordListEmptyState">
				Your words containing <span
					id="stat-wordList-emptyState-trigram"
					class="stat-wordList-trigram"
				></span> will appear here.
			</p>
		</div>
	</div>
	<div id="statList">
		<h2 id="statListTitle">Your Stats</h2>
		<div id="statListValue">
			<div class="stat-statList-item">
				<div
					id="stat-numGamesPlayed"
					class="stat-statList-itemValue"
				></div>
				<div class="stat-statList-itemTitle">
					Played
				</div>
			</div>
			<div class="stat-statList-item">
				<div
					id="stat-winPercentage"
					class="stat-statList-itemValue"
				></div>
				<div class="stat-statList-itemTitle">Win %</div>
			</div>
			<div class="stat-statList-item">
				<div
					id="stat-currentStreak"
					class="stat-statList-itemValue"
				></div>
				<div class="stat-statList-itemTitle">
					Current Streak
				</div>
			</div>
			<div class="stat-statList-item">
				<div
					id="stat-maxStreak"
					class="stat-statList-itemValue"
				></div>
				<div class="stat-statList-itemTitle">
					Max Streak
				</div>
			</div>
			<!-- <div class="stat-statList-item">
				<div
					id="stat-longestWordLength"
					class="stat-statList-itemValue"
				></div>
				<div class="stat-statList-itemTitle">
					Longest Word
				</div>
			</div> -->
		</div>
	</div>
	<div id="statDistribution">
		<h2 id="statDistributionTitle">
			Longest Word Distribution
		</h2>
		<div id="statDistributionValue"></div>
	</div>
</Dialog>

<style>
	h1 {
		font-size: 1.5rem;
		margin-bottom: 1rem;
	}

	h2 {
		font-size: 1.125rem;
		margin-block: 1.25rem 0.75rem;
		border-bottom: 2px solid var(--color-dark);
	}

	#nextGameCountdownDiv {
		display: none;
		text-align: center;
	}

	#wordListValue {
		display: flex;
		flex-flow: column nowrap;
		gap: 0.5rem;
	}

	/* :global — public/js/ui/stats.js builds word list rows at runtime via
	   document.createElement/classList.add, so these elements never get
	   Astro's [data-astro-cid-*] scoping attribute stamped on them. A
	   normal scoped rule would silently never match them. */
	:global(.stat-wordList-level) {
		display: flex;
		flex-flow: row nowrap;
		gap: 0.5rem;
		align-items: center;
	}

	:global(.stat-wordList-length) {
		width: 3ch;
		text-align: right;
	}

	:global(.stat-wordList-word) {
		letter-spacing: 0.25rem;
	}

	:global(.stat-wordList-trigram) {
		border: 1px solid;
		border-radius: 4px;
		padding-left: 0.25rem;
		margin-right: 0.125rem;
		background-color: white;
		letter-spacing: 0.25rem;
	}

	#statListValue {
		display: flex;
		flex-flow: row;
		justify-content: space-between;
	}

	.stat-statList-item {
		width: 7ch;
		display: flex;
		flex-flow: column nowrap;
		text-align: center;
	}

	.stat-statList-itemValue {
		font-size: 2rem;
	}

	#statDistributionValue {
		display: flex;
		flex-flow: column nowrap;
		gap: 0.25rem;
	}

	/* :global — same reason as the word-list rules above: these rows are
	   built at runtime by public/js/ui/stats.js, not rendered by Astro. */
	:global(.stat-statDistribution-item) {
		display: flex;
		flex-flow: row nowrap;
		gap: 0.5rem;
		align-items: center;
	}

	:global(.stat-statDistribution-itemLength) {
		width: 3ch;
		text-align: right;
	}

	:global(.stat-statDistribution-itemCount) {
		padding-inline: 0.5ch;
		background-color: var(--color-dark);
		color: white;
		text-align: right;
	}
</style>
