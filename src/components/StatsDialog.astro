<dialog class="modal-content screen" id="statsDialog">
	<div class="closeRow">
		<div class="closeButton">
			<i class="fa-solid fa-xmark" aria-hidden="true"></i>
		</div>
	</div>
	<div id="nextGameCountdownDiv">
		<p id="nextGameCountdown">Next game starts on Monday</p>
		<br />
	</div>
	<h1 id="statsTitle">Words &amp; Stats</h1>
	<div id="wordList">
		<h2 id="wordListTitle">Your Words</h2>
		<div id="wordListValue">
			<p id="wordListEmptyState">
				Your words containing <span
					id="stat-wordList-emptyState-trigram"
					class="stat-wordList-trigram"
				></span> will appear here.
			</p>
		</div>
	</div>
	<div id="statList">
		<h2 id="statListTitle">Your Stats</h2>
		<div id="statListValue">
			<div class="stat-statList-item">
				<div
					id="stat-numGamesPlayed"
					class="stat-statList-itemValue"
				></div>
				<div class="stat-statList-itemTitle">
					Played
				</div>
			</div>
			<div class="stat-statList-item">
				<div
					id="stat-winPercentage"
					class="stat-statList-itemValue"
				></div>
				<div class="stat-statList-itemTitle">Win %</div>
			</div>
			<div class="stat-statList-item">
				<div
					id="stat-currentStreak"
					class="stat-statList-itemValue"
				></div>
				<div class="stat-statList-itemTitle">
					Current Streak
				</div>
			</div>
			<div class="stat-statList-item">
				<div
					id="stat-maxStreak"
					class="stat-statList-itemValue"
				></div>
				<div class="stat-statList-itemTitle">
					Max Streak
				</div>
			</div>
			<!-- <div class="stat-statList-item">
				<div
					id="stat-longestWordLength"
					class="stat-statList-itemValue"
				></div>
				<div class="stat-statList-itemTitle">
					Longest Word
				</div>
			</div> -->
		</div>
	</div>
	<div id="statDistribution">
		<h2 id="statDistributionTitle">
			Longest Word Distribution
		</h2>
		<div id="statDistributionValue"></div>
	</div>
</dialog>
