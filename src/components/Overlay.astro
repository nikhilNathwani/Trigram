---
// Shared layout for the two full-viewport, centered-content-box screens
// (TrigramRevealScreen, YouWinScreen) — a CSS/layout pattern, distinct from
// the *Screen behavioral contract both already share via modal.js's
// showScreen()/hideScreen() (see the naming-convention comment at the top
// of ui/modal.js). `id` becomes both this element's id and, suffixed with
// "Content", the inner wrapper's — matching what each screen's own <style>
// block and ui/modal.js's #<id>/#<id>Content selectors expect.
const { id } = Astro.props;
---

<div class="overlay screen" id={id}>
	<div class="overlayContent" id={`${id}Content`}>
		<slot />
	</div>
</div>

<style>
	.overlay {
		position: fixed;
		z-index: var(--z-overlay);
		left: 0;
		top: 0;
		width: 100%;
		height: 100%;

		display: flex;
		flex-flow: row nowrap;
		align-items: flex-start;
		justify-content: center;
	}

	.overlayContent {
		width: var(--frame-width);
		height: calc(
			var(--header-height) + var(--game-height) + 2 * var(--game-margin-block)
		);
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		text-align: center;
	}
</style>
