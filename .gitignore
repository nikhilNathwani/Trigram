# Ignore design drafts
mockups/

# Ignore social media content (large image files)
tools/social/instagram_posts/

# Ignore IDE and system files
.vscode/
.DS_Store

# Firebase Admin service account — NEVER commit this
tools/scripts/serviceAccount.json

# Ignore Python cache files
__pycache__/
*.pyc
*.pyo

# Ignore Python virtual environments
.venv/

# Ignore entire corpus folder (large source files)
data/corpus/

# Ignore setup scripts (not currently present, kept in case they come back)
startTrigram.sh
Trigram Update Routine.txt

# Node tooling (test suite)
node_modules/
tests/playwright-report/
tests/test-results/
coverage/

# Claude — everything in here is local/personal (scheduled-task locks, etc.)
# except CLAUDE.md, which is real project documentation and should ship with
# the repo. Excluding contents via ".claude/*" rather than the ".claude/"
# directory itself is required for the negation below to work at all — git
# won't apply a negation to a file whose parent directory is itself ignored.
.claude/*
!.claude/CLAUDE.md

# Personal notes, not meant to be version-controlled — see the untracking/
# history-scrub done alongside this line
INTERVIEW_STORIES.md

# Reference doc kept out of version control by request — tracked history
# up to the untracking commit still has it, going forward it's local-only
tests/TESTING-GUIDE.md

